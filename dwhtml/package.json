{
  "name": "dwhtml",
  "displayName": "DWHTML Visual HTML Editor",
  "description": "Visually edit HTML files directly in VS Code",
  "version": "0.1.0",
  "publisher": "hello432369",
  "author": "hello432369",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/hello432369/dwhtml" },
  "homepage": "https://github.com/hello432369/dwhtml/tree/main",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dwhtml.editHtml",
        "title": "DWHTML: Edit HTML visually"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "command": "dwhtml.editHtml",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "command": "dwhtml.editHtml",
          "group": "navigation"
        }
      ]
    }
  }
}
